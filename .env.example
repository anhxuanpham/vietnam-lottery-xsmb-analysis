ETL_ENV=local
SOURCE_BASE_URL=https://xoso.com.vn
XSMN_FALLBACK_BASE_URL=https://xskt.com.vn
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=1
LOCAL_DATA_DIR=data
LOCAL_OUTPUT_DIR=output
LOCAL_XSMN_OUTPUT_DIR=output-xsmn

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=xsmb-data-lake
R2_XSMN_BUCKET_NAME=xsmn-data-lake
R2_ENDPOINT_URL=
R2_XSMN_ACCOUNT_ID=
R2_XSMN_ACCESS_KEY_ID=
R2_XSMN_SECRET_ACCESS_KEY=
R2_XSMN_ENDPOINT_URL=
R2_REGION=auto
R2_PUBLIC_BASE_URL=
R2_XSMN_PUBLIC_BASE_URL=
R2_CONNECT_TIMEOUT_SECONDS=10
R2_READ_TIMEOUT_SECONDS=60
R2_MAX_RETRIES=5
GOLD_CACHE_CONTROL=public, max-age=300, stale-while-revalidate=60

LOG_LEVEL=INFO
